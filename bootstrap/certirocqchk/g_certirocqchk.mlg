(*i camlp4deps: "grammar/grammar.cma" i*)

DECLARE PLUGIN "rocq-certirocqchk.plugin"

{
open Pp
open Ltac_plugin
open Stdarg
open Procq.Prim
open Plugin_utils
open Certirocq
open G_certirocq_vanilla
}

VERNAC COMMAND EXTEND CertiRocqCheck CLASSIFIED AS QUERY
| [ "CertiRocqCheck" global(gr) ] -> {
    let gr = Nametab.global gr in
    Certirocqchk.check gr
  }
(* | [ "CertiRocqCheck" "-help" ] -> { *)
    (* Feedback.msg_info (str help_msg) *)
  (* } *)
END
