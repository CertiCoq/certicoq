(*i camlp4deps: "grammar/grammar.cma" i*)

DECLARE PLUGIN "rocq-certirocq-bootstrapped-erasure.plugin"

{
open Pp
open Ltac_plugin
open Stdarg
open Pcoq.Prim

}

VERNAC COMMAND EXTEND CertiRocq_Erasure CLASSIFIED AS QUERY
| [ "CertiRocq" "Bypass" "Erase" constr(c) ] -> {
    let env = Global.env () in
    let evm = Evd.from_env env in
    let (c, _) = Constrintern.interp_constr env evm c in    
    CertiRocqErase.erase ~bypass:true env evm c
  }
| [ "CertiRocq" "Erase" constr(c) ] -> {
    let env = Global.env () in
    let evm = Evd.from_env env in
    let (c, _) = Constrintern.interp_constr env evm c in    
    CertiRocqErase.erase ~bypass:false env evm c
  }
END
